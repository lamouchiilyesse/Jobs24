<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}TalentBridge{% endblock %} · Find Your Next Opportunity</title>

        <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">

        <script src="https://cdn.tailwindcss.com"></script>

        <script src="{{ asset('tailwind.config.js') }}"></script>

        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">

        {% block importmap %}{{ importmap('app') }}{% endblock %}
    </head>

    <body class="min-h-screen flex flex-col">
    {# templates/base.html.twig #}

    <div class="container">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>
    <!-- Navbar -->
    <nav class="bg-white/80 backdrop-blur-md border-b border-gray-100 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">

                <a href="{{ path('index') }}" class="flex items-center gap-2 flex-shrink-0">
                    <div class="w-8 h-8 bg-brand-500 rounded-xl flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                        </svg>
                    </div>
                    <span class="font-display font-600 text-xl text-gray-900 hidden sm:block">Talent<span class="text-brand-500">Bridge</span></span>
                </a>

                <div class="hidden md:flex items-center gap-8">
                    <a href="#" class="nav-link text-gray-600 hover:text-gray-900 font-500 text-sm transition-colors">Companies</a>
                    <a href="#" class="nav-link text-gray-600 hover:text-gray-900 font-500 text-sm transition-colors">For Employers</a>
                </div>

                <div class="flex items-center gap-2 sm:gap-3">
                    <a href="#" class="text-xs sm:text-sm font-700 text-gray-600 hover:text-gray-900 transition-colors px-2 py-1.5">
                        <button onclick="toggleModal()" class="text-sm font-bold text-gray-700 hover:text-brand-600">
                            Log in
                        </button>
                    </a>

                    {# Register Dropdown #}
                    <div class="relative group">
                        <button class="text-xs sm:text-sm font-bold text-white bg-brand-500 hover:bg-brand-600 transition-all px-3 py-2 sm:px-4 rounded-xl shadow-sm flex items-center gap-1">
                            Join <span class="hidden sm:inline">Now</span>
                            <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        </button>

                        <div class="absolute right-0 mt-2 w-56 bg-white border border-gray-100 rounded-2xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 p-2">
                            <a href="javascript:void(0)" onclick="openRegisterModal('job_seeker')" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-brand-50 rounded-xl transition-colors">
                                <div class="bg-brand-100 p-2 rounded-lg text-brand-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2"/></svg>
                                </div>
                                <div>
                                    <span class="block font-bold">As Job Seeker</span>
                                    <span class="text-xs text-gray-500">Find your next role</span>
                                </div>
                            </a>

                            <a href="javascript:void(0)" onclick="openRegisterModal('employer')" class="flex items-center gap-3 px-4 py-3 text-sm text-gray-700 hover:bg-brand-50 rounded-xl transition-colors mt-1">
                                <div class="bg-sky-100 p-2 rounded-lg text-sky-600">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5" stroke-width="2"/></svg>
                                </div>
                                <div>
                                    <span class="block font-bold">As Employer</span>
                                    <span class="text-xs text-gray-500">Hire top talent</span>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </nav>




    <!-- Main content -->
    <main class="flex-1">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-100 mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div class="col-span-1">
                    <div class="flex items-center gap-2 mb-4">
                        <div class="w-7 h-7 bg-brand-500 rounded-lg flex items-center justify-center">
                            <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <span class="font-display font-600 text-lg text-gray-900">Talent<span class="text-brand-500">Bridge</span></span>
                    </div>
                    <p class="text-sm text-gray-500 leading-relaxed">Connecting talent with opportunity. Find your dream job or your next great hire.</p>
                </div>
                <div>
                    <h4 class="font-700 text-gray-800 text-sm mb-4">For Job Seekers</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
{#                        {{ path('app_jobs') }}#}
                        <li><a href="" class="hover:text-brand-600 transition-colors">Browse Jobs</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Create Profile</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Career Advice</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-700 text-gray-800 text-sm mb-4">For Employers</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Post a Job</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Search Candidates</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Pricing</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-700 text-gray-800 text-sm mb-4">Company</h4>
                    <ul class="space-y-2 text-sm text-gray-500">
                        <li><a href="#" class="hover:text-brand-600 transition-colors">About Us</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Privacy Policy</a></li>
                        <li><a href="#" class="hover:text-brand-600 transition-colors">Terms of Service</a></li>
                    </ul>
                </div>
            </div>
            <div class="border-t border-gray-100 mt-10 pt-6 text-center text-xs text-gray-400">
                © {{ "now"|date("Y") }} TalentBridge. All rights reserved.
            </div>
        </div>
    </footer>
{#    sign in block#}
    {# templates/base.html.twig #}

    {# templates/base.html.twig #}

    <div id="authModal" class="fixed inset-0 z-[100] hidden bg-gray-900/95 backdrop-blur-md overflow-y-auto px-6 py-12">

        <button type="button" onclick="toggleModal()" class="fixed right-6 top-6 text-white/50 hover:text-white z-[110]">
            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <div id="modalContainer" class="sm:mx-auto sm:w-full sm:max-w-sm scale-95 opacity-0 transition-all duration-300">
            <div class="text-center">
                <img src="https://tailwindcss.com/plus-assets/img/logos/mark.svg?color=indigo&shade=500" alt="TalentBridge" class="mx-auto h-10 w-auto" />
                <h2 class="mt-10 text-2xl font-bold tracking-tight text-white">Sign in to your account</h2>
            </div>

            <div class="mt-10">
{#                <form action="{{ path('app_login') }}" method="POST" class="space-y-6">#}
                    <div>
                        <button type="submit" class="flex w-full justify-center rounded-md bg-indigo-500 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-400">
                            Sign in
                        </button>
                    </div>
{#                </form>#}

                <div class="mt-6">
                    <div class="relative">
                        <div class="absolute inset-0 flex items-center" aria-hidden="true">
                            <div class="w-full border-t border-white/10"></div>
                        </div>
                        <div class="relative flex justify-center text-sm/6 font-medium">
                            <span class="bg-gray-900 px-4 text-gray-400">Or continue with</span>
                        </div>
                    </div>

                    <div class="mt-6">
{#                        <a href="{{ path('connect_google_start') }}"#}
                           class="flex w-full items-center justify-center gap-3 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm hover:bg-gray-100 transition-colors">
                            <svg class="h-5 w-5" viewBox="0 0 24 24">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.66l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                            </svg>
                            <span>Google</span>
{#                        </a>#}
                    </div>
                </div>

                <p class="mt-10 text-center text-sm/6 text-gray-400">
                    Not a member?
                    <a href="#" class="font-semibold text-indigo-400 hover:text-indigo-300">Start a 14 day free trial</a>
                </p>
            </div>
        </div>
    </div>
    {#  end  sign in block#}

    {% block javascripts %}
        {{ importmap('app') }}
    {% endblock %}

    </body>
</html>
