{% extends 'base.html.twig' %}

{% block title %}Home - TalentBridge{% endblock %}

{% block body %}
    <!-- Flash Messages Container -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="rounded-xl p-4 mb-4 text-sm flex items-center gap-3 {{ label == 'success' ? 'bg-brand-100 text-brand-700' : 'bg-red-100 text-red-700' }}">
                    <span class="w-2 h-2 rounded-full {{ label == 'success' ? 'bg-brand-500' : 'bg-red-500' }}"></span>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-sky-50 pt-20 pb-24">
        <div class="absolute top-0 right-0 w-96 h-96 bg-brand-100 rounded-full blur-3xl opacity-40 -translate-y-1/2 translate-x-1/2"></div>
        <div class="absolute bottom-0 left-0 w-80 h-80 bg-peach-100 rounded-full blur-3xl opacity-40 translate-y-1/2 -translate-x-1/2"></div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto">
                <div class="inline-flex items-center gap-2 bg-brand-50 border border-brand-200 text-brand-700 text-xs font-700 px-3 py-1.5 rounded-full mb-6 animate-fade-in">
                    <span class="w-1.5 h-1.5 bg-brand-500 rounded-full"></span>
                    Over 10,000 jobs available right now
                </div>

                <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-600 text-gray-900 leading-tight mb-6 animate-fade-up" style="animation-delay:0.1s">
                    Find the job you
                    <span class="text-brand-500 italic"> truly love</span>
                </h1>
                <p class="text-lg text-gray-500 leading-relaxed mb-10 animate-fade-up" style="animation-delay:0.2s">
                    TalentBridge connects ambitious professionals with companies that share their values. Your next chapter starts here.
                </p>

                <!-- Search bar -->
                <div class="animate-fade-up" style="animation-delay:0.3s">
                    <form action="#" method="GET" class="flex flex-col sm:flex-row gap-3 bg-white p-2 rounded-2xl shadow-lg border border-gray-100 max-w-2xl mx-auto">
                        <div class="flex items-center gap-3 flex-1 px-3">
                            <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                            <input type="text" name="q" placeholder="Job title, keyword..." class="w-full text-sm text-gray-700 placeholder-gray-400 outline-none py-2 font-500">
                        </div>
                        <div class="flex items-center gap-3 px-3 border-t sm:border-t-0 sm:border-l border-gray-100 flex-1">
                            <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            </svg>
                            <input type="text" name="location" placeholder="City or remote..." class="w-full text-sm text-gray-700 placeholder-gray-400 outline-none py-2 font-500">
                        </div>
                        <button type="submit" class="bg-brand-500 hover:bg-brand-600 text-white font-700 text-sm px-6 py-3 rounded-xl transition-colors shrink-0 shadow-sm">
                            Search Jobs
                        </button>
                    </form>
                </div>
            </div>
            <!-- Registration CTA in Hero -->
            <div class="flex flex-wrap justify-center gap-4 mt-10 animate-fade-up" style="animation-delay:0.4s">
                <a href="{{ path('register_job_seeker') }}"
                   class="group flex items-center gap-3 bg-white border border-gray-200 hover:border-brand-500 px-6 py-3 rounded-2xl transition-all shadow-sm hover:shadow-md">
                    <div class="w-10 h-10 bg-brand-50 rounded-xl flex items-center justify-center group-hover:bg-brand-500 transition-colors">
                        <svg class="w-5 h-5 text-brand-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                    <div class="text-left">
                        <div class="text-xs text-gray-400 font-700 uppercase tracking-wider">I want to</div>
                        <div class="text-sm font-800 text-gray-800">Find a Job</div>
                    </div>
                </a>

                <a href="{{ path('register_job_seeker') }}"
                   class="group flex items-center gap-3 bg-white border border-gray-200 hover:border-brand-500 px-6 py-3 rounded-2xl transition-all shadow-sm hover:shadow-md">
                    <div class="w-10 h-10 bg-brand-50 rounded-xl flex items-center justify-center group-hover:bg-brand-500 transition-colors">
                        <svg class="w-5 h-5 text-brand-600 group-hover:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/>
                        </svg>
                    </div>
                    <div class="text-left">
                        <div class="text-xs text-gray-400 font-700 uppercase tracking-wider">I want to</div>
                        <div class="text-sm font-800 text-gray-800">Hire Talent</div>
                    </div>
                </a>
            </div>
            <!-- Stats -->
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-16 max-w-3xl mx-auto animate-fade-up" style="animation-delay:0.5s">
                {% for stat in [
                    {'value': '10K+', 'label': 'Active Jobs'},
                    {'value': '3K+', 'label': 'Companies'},
                    {'value': '50K+', 'label': 'Candidates'},
                    {'value': '98%', 'label': 'Satisfaction'}
                ] %}
                    <div class="text-center bg-white rounded-2xl p-4 shadow-sm border border-gray-100">
                        <div class="font-display text-2xl font-600 text-gray-900">{{ stat.value }}</div>
                        <div class="text-xs text-gray-500 font-500 mt-0.5">{{ stat.label }}</div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- Featured Jobs Section -->
    <section class="py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
            <div>
                <h2 class="font-display text-3xl font-600 text-gray-900">Featured <span class="text-brand-500 italic">Jobs</span></h2>
                <p class="text-gray-500 text-sm mt-1">Hand-picked opportunities just for you</p>
            </div>
{#            path('app_jobs') }}#}
            <a href="" class="text-sm font-700 text-brand-600 hover:text-brand-700 flex items-center gap-1 transition-colors">
                View all
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
            {# ... Job Loop (Keep your existing job array here) ... #}
        </div>
    </section>

    <!-- How it works -->
    <section class="bg-gradient-to-br from-gray-50 to-brand-50 py-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14">
                <h2 class="font-display text-3xl font-600 text-gray-900">How <span class="text-brand-500 italic">it works</span></h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {% set steps = [
                    {'num': '01', 'title': 'Create your profile', 'desc': "Sign up and showcase your skills, experience, and what you're looking for in your next role.", 'icon': 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'},
                    {'num': '02', 'title': 'Explore opportunities', 'desc': 'Browse thousands of curated job listings filtered to match your skills and preferences.', 'icon': 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z'},
                    {'num': '03', 'title': 'Land your dream job', 'desc': 'Apply with one click, track your applications, and get hired by amazing companies.', 'icon': 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z'}
                ] %}
                {% for step in steps %}
                    <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm relative overflow-hidden">
                        <div class="absolute top-4 right-4 font-display text-6xl font-800 text-gray-50 select-none">{{ step.num }}</div>
                        <div class="w-12 h-12 bg-brand-50 rounded-2xl flex items-center justify-center mb-5 relative z-10">
                            <svg class="w-6 h-6 text-brand-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ step.icon }}"/>
                            </svg>
                        </div>
                        <h3 class="font-700 text-gray-900 text-lg mb-2 relative z-10">{{ step.title }}</h3>
                        <p class="text-sm text-gray-500 leading-relaxed relative z-10">{{ step.desc }}</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-brand-500 to-brand-600 rounded-4xl p-12 text-center relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative">
                <h2 class="font-display text-4xl font-600 text-white mb-4">Ready to find your next <span class="italic">great hire?</span></h2>
                <p class="text-brand-100 text-sm mb-8 max-w-md mx-auto">Post your job in minutes and reach thousands of qualified candidates.</p>
                <div class="flex flex-col sm:flex-row gap-3 justify-center">
                    <a href="{{ path('register_recruiter') }}" class="bg-white text-brand-600 font-700 text-sm px-8 py-3.5 rounded-2xl hover:bg-brand-50 transition-colors shadow-sm">Post a Job — it's free</a>
{#                    <a href="{{ path('app_jobs') }}" class="bg-brand-400/30 text-white font-700 text-sm px-8 py-3.5 rounded-2xl hover:bg-brand-400/40 transition-colors border border-white/20">Browse candidates</a>#}
                </div>
            </div>
        </div>
    </section>
{% endblock %}